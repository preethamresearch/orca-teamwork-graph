# ============================================================================
# Oracle backend configuration
# Copy to `.env` and fill in to run against live Azure AI Foundry.
# If left blank, the backend runs in LOCAL-DEMO mode (grounded retrieval over
# the bundled enterprise knowledge base, no cloud calls required).
# ============================================================================

# Set to "true" to force local-demo mode even if Azure creds are present.
ORACLE_LOCAL_DEMO=false

# --- Azure AI Foundry (Foundry IQ grounding + Agent Service) ---
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_AGENT_MODEL=gpt-4o
# Foundry IQ knowledge base / Azure AI Search index used for grounded retrieval
FOUNDRY_IQ_SEARCH_ENDPOINT=
FOUNDRY_IQ_SEARCH_INDEX=oracle-enterprise-kb
FOUNDRY_IQ_SEARCH_KEY=

# --- Work IQ (Microsoft Graph: live M365 work context) ---
# Leave blank to use the bundled sample work-context. Fill in for live M365.
WORK_IQ_TENANT_ID=
WORK_IQ_CLIENT_ID=
WORK_IQ_CLIENT_SECRET=

# --- Server ---
ORACLE_HOST=127.0.0.1
ORACLE_PORT=8000
ORACLE_ALLOWED_ORIGINS=chrome-extension://*
