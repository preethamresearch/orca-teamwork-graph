  "projects": [
    {"id": "proj_checkout", "name": "Checkout v2", "team": "team_payments", "status": "in_progress", "summary": "Re-platform the checkout flow onto the new service mesh with tokenized payments."},
    {"id": "proj_tokens", "name": "Identity Tokens", "team": "team_identity", "status": "in_progress", "summary": "Issue short-lived JWTs for service-to-service and user auth."},
    {"id": "proj_mesh", "name": "Platform Service Mesh", "team": "team_platform", "status": "in_progress", "summary": "Shared service mesh, secrets, and deploy pipeline for all squads."},
    {"id": "proj_wallet", "name": "Mobile Wallet", "team": "team_mobile", "status": "planned", "summary": "In-app wallet that consumes the new checkout APIs."},
    {"id": "proj_pipeline", "name": "Events Data Pipeline", "team": "team_data", "status": "in_progress", "summary": "Stream platform events from Service Bus into the analytics lakehouse."},
    {"id": "proj_fraud", "name": "Fraud Detection", "team": "team_data", "status": "in_progress", "summary": "Real-time fraud scoring on checkout transactions using the events pipeline."},
    {"id": "proj_authz", "name": "Authorization Service", "team": "team_identity", "status": "planned", "summary": "Centralized RBAC/ABAC authorization built on the new identity tokens."},
    {"id": "proj_observability", "name": "Observability Platform", "team": "team_platform", "status": "in_progress", "summary": "Org-wide tracing, metrics, and dashboards on top of the service mesh."},
    {"id": "proj_zerotrust", "name": "Zero Trust Rollout", "team": "team_security", "status": "in_progress", "summary": "Enforce device + identity posture checks across all internal services."}
  ],
  "decisions": [
    {"id": "dec_jwt", "title": "Adopt JWT with 30-minute expiry for all tokens", "date": "2026-05-20", "status": "approved", "summary": "Standardize on signed JWTs with 30-min TTL and refresh tokens; SMS codes disallowed for privileged accounts."},
    {"id": "dec_2person", "title": "Require 2-person approval for production deploys", "date": "2026-06-01", "status": "approved", "summary": "All production deploys go through GitOps with a mandatory second approver in contoso/deploy."},
    {"id": "dec_cosmos", "title": "Use Cosmos DB for high-volume events", "date": "2026-04-15", "status": "approved", "summary": "Async/high-volume event data lands in Cosmos DB; Azure SQL stays transactional."},
    {"id": "dec_rollout", "title": "Phased rollout of Checkout v2", "date": "2026-06-09", "status": "proposed", "summary": "Ship Checkout v2 to 5% then 25% then 100% of traffic, gated on error budget."},
    {"id": "dec_rbac", "title": "Standardize on RBAC for the Authorization Service", "date": "2026-06-05", "status": "approved", "summary": "Role-based access control as the default model, with attribute checks for sensitive scopes."},
    {"id": "dec_fraud_model", "title": "Use a streaming gradient-boosted model for fraud scoring", "date": "2026-05-28", "status": "approved", "summary": "Score transactions in-stream with a periodically retrained GBM; human review queue for high-risk."},
    {"id": "dec_otel", "title": "Adopt OpenTelemetry as the observability standard", "date": "2026-03-30", "status": "approved", "summary": "All services emit OTel traces/metrics into Azure Monitor and Grafana."},
    {"id": "dec_zerotrust", "title": "Enforce device posture for internal access", "date": "2026-06-03", "status": "proposed", "summary": "Require managed-device + MFA posture before granting service access; phased by team."}
  ],
