{
  "manifest_version": 3,
  "name": "Orca — Teamwork Graph",
  "version": "0.1.0",
  "description": "Bring Teamwork Graph answers into any web page. Ask Orca from a popup or an in-page panel, grounded in your current page selection.",
  "action": {
    "default_title": "Orca — Teamwork Graph",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/markdown.js", "lib/render.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Toggle the Orca in-page panel"
    }
  },
  "permissions": ["activeTab", "scripting", "storage", "commands"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
